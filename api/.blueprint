    - database/factories/MandateFactory.php
    - database/factories/TopicFactory.php
    - database/factories/QuestionFactory.php
    - database/factories/AnswerFactory.php
    - database/factories/VoteFactory.php
    - database/migrations/2026_03_23_185915_create_cantons_table.php
    - database/migrations/2026_03_23_185916_create_parties_table.php
    - database/migrations/2026_03_23_185917_create_councils_table.php
    - database/migrations/2026_03_23_185918_create_politicians_table.php
    - database/migrations/2026_03_23_185919_create_mandates_table.php
    - database/migrations/2026_03_23_185920_create_topics_table.php
